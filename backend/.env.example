# WorkPulse Backend Environment
# Copy this to .env and fill in your values

NODE_ENV=development
PORT=4000

# PostgreSQL — local dev default
DATABASE_URL=postgresql://workpulse:workpulse@localhost:5432/workpulse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=workpulse
POSTGRES_USER=workpulse
POSTGRES_PASSWORD=workpulse

# Redis — local dev default
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limits (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_AUTHENTICATED=500
RATE_LIMIT_PREDICT=20

# JWT (for future auth hardening)
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=7d
