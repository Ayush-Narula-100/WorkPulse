# =============================================================================
# WorkPulse / WorkLoadIQ Pro — Comprehensive .gitignore
# Covers: Node.js, TypeScript, Next.js, Docker, OS, IDE
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Environment Variables — NEVER commit secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local

# Keep the example files
!.env.example

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.output/

# Next.js
.next/
next-env.d.ts

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Runtime / Cache
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Next.js cache
.next/cache/

# Prisma
prisma/.env

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# Docker (local override files only)
# -----------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# PostgreSQL dumps
*.dump
*.sql.gz

# Redis
dump.rdb

# -----------------------------------------------------------------------------
# Package manager locks — keep one, ignore others
# -----------------------------------------------------------------------------
# Keeping package-lock.json (npm)
# yarn.lock
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------

# VS Code (keep workspace settings, ignore personal)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*
.emacs.desktop
.emacs.desktop.lock

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# Storybook
storybook-static/

# Sentry
.sentryclirc

# Vercel
.vercel

# Netlify
.netlify

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Local scripts / scratch
scratch/
tmp/
temp/

# GSD Planning (internal workflow — exclude from public repo)
.planning/
